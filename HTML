<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>AoS 4th • Damage Calculator v0.52</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:#0a0a0a; font-family:Georgia,'Times New Roman',serif; color:#e0e0e0; font-size:15px; line-height:1.5; padding-bottom:85px; -webkit-tap-highlight-color:transparent; user-select:none; }
    .app { max-width:750px; margin:0 auto; padding:12px 10px; }
    .wgh-banner { background:#0d0d0d; border-bottom:2px solid #c9a84c; text-align:center; padding:12px 0 8px; margin-bottom:12px; }
    .wgh-banner span { font-family:Georgia,'Times New Roman',serif; font-size:28px; letter-spacing:10px; color:#c9a84c; text-transform:uppercase; text-shadow:0 0 10px #000, 0 0 20px #c9a84c; }
    .screen { display:none; } .screen.active { display:block; }
    h2,h3,h4 { color:#c9a84c; font-weight:normal; letter-spacing:1px; margin-bottom:10px; }
    .card { background:#111; border:1px solid rgba(201,168,76,0.3); border-radius:10px; padding:14px; margin-bottom:14px; }
    .card-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; flex-wrap:wrap; gap:6px; }
    .profile-name { background:transparent; border:1px solid rgba(201,168,76,0.4); color:#c9a84c; font-family:Georgia,serif; font-size:16px; padding:8px 10px; border-radius:8px; width:150px; }
    .colour-dot { width:16px; height:16px; border-radius:50%; display:inline-block; margin-right:6px; flex-shrink:0; }
    .weapon-card { background:#181818; border:1px solid rgba(201,168,76,0.2); border-radius:8px; padding:10px; margin:8px 0; }
    .weapon-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; gap:6px; }
    .weapon-name { background:transparent; border:1px solid rgba(201,168,76,0.3); color:#c0c0c0; font-family:Georgia,serif; font-size:14px; padding:6px 8px; border-radius:6px; width:120px; }
    .stepper-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; flex-wrap:wrap; gap:4px; }
    .stepper-label { font-size:13px; color:#aaa; width:65px; flex-shrink:0; }
    .stepper-control { display:flex; align-items:center; gap:2px; background:#1a1a1a; border-radius:8px; padding:3px; }
    .stepper-btn { background:#2a2a2a; border:none; color:#c9a84c; font-size:22px; font-weight:bold; width:48px; height:48px; border-radius:8px; cursor:pointer; touch-action:manipulation; display:flex; align-items:center; justify-content:center; }
    .stepper-btn:active { background:#3a3a3a; }
    .stepper-btn.small { width:36px; height:36px; font-size:18px; }
    .stepper-value { min-width:48px; text-align:center; font-size:18px; color:#e0e0e0; font-weight:bold; padding:0 6px; }
    .damage-input { background:#1a1a1a; border:1px solid rgba(201,168,76,0.4); color:#e0e0e0; font-family:Georgia,serif; font-size:16px; padding:10px; border-radius:8px; width:100px; text-align:center; }
    .damage-input:focus { outline:1px solid #c9a84c; }
    .damage-input.invalid { border-color:#c0392b; }
    .error-hint { color:#c0392b; font-size:11px; margin-left:4px; display:none; }
    .error-hint.visible { display:inline; }
    .radio-group { display:flex; flex-wrap:wrap; gap:8px; margin:4px 0; }
    .radio-option, .toggle-option { display:flex; align-items:center; gap:6px; background:#1a1a1a; padding:6px 12px; border-radius:16px; border:1px solid rgba(201,168,76,0.3); font-size:12px; cursor:pointer; }
    .radio-option input, .toggle-option input { accent-color:#c9a84c; width:16px; height:16px; }
    .leader-toggle { display:flex; align-items:center; gap:8px; background:#1a1a1a; padding:8px 14px; border-radius:20px; border:1px solid rgba(201,168,76,0.3); font-size:13px; cursor:pointer; }
    .leader-toggle input { accent-color:#c9a84c; width:18px; height:18px; }
    .summary-line { font-size:14px; color:#c9a84c; margin-top:8px; font-style:italic; border-top:1px solid rgba(201,168,76,0.2); padding-top:8px; }
    .btn { background:#2a2a2a; border:1px solid #c9a84c; color:#c9a84c; padding:12px 18px; border-radius:8px; font-size:15px; font-family:Georgia,serif; cursor:pointer; min-height:48px; touch-action:manipulation; margin-right:6px; margin-bottom:6px; }
    .btn:active { background:#3a3a3a; }
    .btn.danger { border-color:#c0392b; color:#c0392b; }
    .btn.small { font-size:12px; padding:6px 10px; min-height:32px; }
    .btn.tiny { font-size:11px; padding:4px 8px; min-height:28px; }
    .visibility-toggle { display:flex; align-items:center; gap:6px; font-size:12px; color:#aaa; cursor:pointer; }
    .visibility-toggle input { accent-color:#c9a84c; }
    .bottom-nav { position:fixed; bottom:0; left:0; right:0; background:#0a0a0a; border-top:1px solid rgba(201,168,76,0.4); display:flex; justify-content:space-around; padding:6px 2px; z-index:100; }
    .nav-btn { background:transparent; border:none; color:#888; font-size:12px; font-family:Georgia,serif; display:flex; flex-direction:column; align-items:center; gap:2px; padding:8px 4px; border-radius:12px; min-width:65px; cursor:pointer; touch-action:manipulation; }
    .nav-btn.active { color:#c9a84c; background:#1a1a1a; }
    .nav-btn span:first-child { font-size:20px; }
    svg { display:block; background:#0a0a0a; border-radius:8px; }
    .chart-scroll { width:100%; overflow-x:auto; -webkit-overflow-scrolling:touch; padding-bottom:4px; }
    .chart-scroll svg { width:auto; max-width:none; min-width:600px; height:auto; }
    .scroll-hint { text-align:center; color:#888; font-size:11px; padding:4px; display:none; }
    @media (max-width:650px){ .scroll-hint{ display:block; } }
    table { width:100%; border-collapse:collapse; margin-top:10px; font-size:13px; }
    th { color:#c9a84c; text-align:left; padding:8px 4px; border-bottom:1px solid rgba(201,168,76,0.3); }
    td { padding:8px 4px; border-bottom:1px solid #222; }
    .best-cell { color:#c9a84c; font-weight:bold; }
    .flex-row { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin:8px 0; }
    select { background:#1a1a1a; color:#e0e0e0; border:1px solid #c9a84c; padding:10px; border-radius:8px; font-family:Georgia,serif; font-size:15px; min-height:48px; }
    .stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:6px; font-size:13px; }
    .bar-row { display:flex; align-items:center; gap:8px; margin:4px 0; }
    .bar-label { width:80px; text-align:right; font-size:12px; color:#e0e0e0; flex-shrink:0; }
    .bar-fill { height:18px; border-radius:4px; min-width:2px; transition:width 0.3s; }
    .pct { color:#c9a84c; }
    .total-attacks-info { color:#aaa; font-size:12px; margin-bottom:4px; }
    .version-badge { display:inline-block; background:#c9a84c; color:#000; font-size:9px; padding:2px 8px; border-radius:8px; margin-left:6px; vertical-align:middle; }
    .toggle-combine { display:inline-flex; align-items:center; gap:6px; background:#1a1a1a; border:1px solid rgba(201,168,76,0.3); padding:6px 12px; border-radius:16px; font-size:12px; cursor:pointer; }
    .toggle-combine input { accent-color:#c9a84c; }
    .debuff-section { margin-top:8px; display:flex; flex-wrap:wrap; align-items:center; gap:10px; }
  </style>
</head>
<body>
<div class="app" id="app">
  <div class="wgh-banner"><span>WGH Warducks</span></div>
  <div id="screen1" class="screen active"><h2>⚔️ Attack Profiles <span class="version-badge">v0.52</span></h2><div id="profilesContainer"></div><button class="btn" id="addProfileBtn">➕ Add Profile</button></div>
  <div id="screen2" class="screen"><h2>📊 Save Comparison</h2><div class="flex-row"><label style="color:#e0e0e0;">Ward: <select id="globalWardSelect"><option value="0">None</option><option value="6">6+</option><option value="5">5+</option><option value="4">4+</option></select></label><label class="toggle-combine"><input type="checkbox" id="combineWeaponsToggle" onchange="combineWeapons=this.checked;renderScreen2();renderScreen3();"> Combine weapons</label></div><div id="saveChartContainer" class="card" style="padding:6px;"></div><div id="saveTableContainer"></div></div>
  <div id="screen3" class="screen"><h2>🎲 Damage Distribution</h2><div class="flex-row"><label style="color:#e0e0e0;">Save: <select id="distSaveSelect"><option value="0">None</option><option value="6">6+</option><option value="5">5+</option><option value="4" selected>4+</option><option value="3">3+</option><option value="2">2+</option></select></label><label style="color:#e0e0e0;">Ward: <select id="distWardSelect"><option value="0">None</option><option value="6">6+</option><option value="5">5+</option><option value="4">4+</option></select></label><label style="color:#e0e0e0;">Show: <select id="distProfileSelect"><option value="all">All Profiles</option></select></label></div><div id="distChartContainer" class="card chart-scroll" style="padding:6px;"><div class="scroll-hint">← scroll chart →</div></div><div id="distStatsContainer" class="card"></div></div>
  <div id="screen4" class="screen"><h2>💀 Kill Probability</h2><div class="card"><div class="stepper-row"><span class="stepper-label">Wounds</span><div class="stepper-control" id="killWoundsStepper"></div></div><div class="stepper-row"><span class="stepper-label">Models</span><div class="stepper-control" id="killModelsStepper"></div></div><div class="flex-row"><label style="color:#e0e0e0;">Save: <select id="killSaveSelect"><option value="0">None</option><option value="6">6+</option><option value="5">5+</option><option value="4">4+</option><option value="3">3+</option><option value="2">2+</option></select></label><label style="color:#e0e0e0;">Ward: <select id="killWardSelect"><option value="0">None</option><option value="6">6+</option><option value="5">5+</option><option value="4">4+</option></select></label></div><div class="debuff-section"><span style="color:#aaa;font-size:13px;">Debuffs:</span><div id="debuffToggles" style="display:flex;flex-wrap:wrap;gap:8px;"></div><button class="btn tiny" onclick="clearDebuffs()">Clear all</button></div></div><div id="killStatsContainer"></div><div id="killChartContainer" class="card" style="padding:6px;"></div><div id="killBreakdownContainer" class="chart-scroll"><div class="scroll-hint">← scroll table →</div></div></div>
</div>
<nav class="bottom-nav">
  <button class="nav-btn active" data-screen="1"><span>⚔️</span>Profiles</button>
  <button class="nav-btn" data-screen="2"><span>📊</span>Saves</button>
  <button class="nav-btn" data-screen="3"><span>🎲</span>Dist</button>
  <button class="nav-btn" data-screen="4"><span>💀</span>Kill</button>
</nav>

<script>
  // ==================== v0.52 ENGINE (debuff fixes, checkboxes) ====================
  let combineWeapons = true;
  const PALETTE = ['#c9a84c', '#cd7f32', '#c0c0c0', '#7f8c8d'];
  let profiles = [], distSelectedVal = 'all', killState = { wounds:2, models:5 }, pendingRender = false;
  let killDebuffs = { hit: false, wound: false, attacks: false };

  // --- dice parsing & distributions (unchanged) ---
  function parseDiceExpr(expr) {
    const t = String(expr).trim().replace(/\s+/g, '');
    if (/^\d+$/.test(t)) return { type: 'fixed', value: parseInt(t), valid: true };
    const parts = t.split('+');
    let dice = [], constant = 0;
    for (let p of parts) {
      p = p.trim();
      if (/^\d+$/.test(p)) { constant += parseInt(p); continue; }
      let m = p.match(/^(\d*)D(\d+)$/i);
      if (m) {
        let count = m[1] ? parseInt(m[1]) : 1, sides = parseInt(m[2]);
        if (sides < 2 || sides > 6 || count < 1 || count > 20) return { valid: false, error: 'D3/D6' };
        for (let i = 0; i < count; i++) dice.push(sides);
        continue;
      }
      return { valid: false, error: 'Invalid' };
    }
    if (dice.length === 0) return { type: 'fixed', value: constant, valid: true };
    return { type: 'dice', dice, constant, valid: true };
  }

  function singleDieDist(sides) { let d = []; for (let i = 1; i <= sides; i++) d.push({ value: i, prob: 1 / sides }); return d; }
  function convolveArrays(a, b) { let map = new Map(); for (let x of a) for (let y of b) { let v = x.value + y.value; map.set(v, (map.get(v) || 0) + x.prob * y.prob); } let r = []; for (let [v, p] of map) r.push({ value: v, prob: p }); r.sort((a, b) => a.value - b.value); return r; }
  function distribution(expr) { let p = parseDiceExpr(expr); if (!p || !p.valid) return null; if (p.type === 'fixed') return [{ value: p.value, prob: 1.0 }]; let d = [{ value: 0, prob: 1.0 }]; for (let s of p.dice) d = convolveArrays(d, singleDieDist(s)); if (p.constant) d = d.map(x => ({ value: x.value + p.constant, prob: x.prob })); return d; }
  function expectedValue(d) { return d.reduce((a, x) => a + x.value * x.prob, 0); }
  function probGE(d, t) { return d.reduce((a, x) => a + (x.value >= t ? x.prob : 0), 0); }
  function validateExpression(e) { let p = parseDiceExpr(e); return p && p.valid; }

  function shiftDistribution(d, amount) {
    if (!d || d.length === 0) return d;
    return d.map(x => ({ value: Math.max(0, x.value + amount), prob: x.prob }));
  }

  // *** FIXED: debuff now INCREASES required roll (harder to hit/wound) ***
  function singleAttackDistribution(weapon, saveChar, wardVal, allowExtra = true, debuffs = null) {
    // ‑1 Hit: increase required hit value by 1
    const hitMod = debuffs?.hit ? 1 : 0;
    const hitTarget = Math.min(6, weapon.hit + hitMod);
    const pMiss = (hitTarget - 1) / 6;
    const pHit = (7 - hitTarget - 1) / 6;
    const pCrit = 1 / 6;

    // ‑1 Wound: increase required wound value by 1
    const woundMod = debuffs?.wound ? 1 : 0;
    const woundTarget = Math.min(6, weapon.wound + woundMod);
    const pWound = (7 - woundTarget) / 6;

    const es = saveChar === 0 ? 7 : saveChar + weapon.rend;
    const effSave = es > 6 ? 7 : es;
    const pFail = effSave <= 6 ? 1 - Math.max(0, (7 - effSave) / 6) : 1;
    const pWardPass = wardVal ? 1 - (7 - wardVal) / 6 : 1;
    const dmgDist = distribution(weapon.damage);
    if (!dmgDist) return null;
    const critType = weapon.critType;
    const out = new Map();
    const add = (dmg, prob) => out.set(dmg, (out.get(dmg) || 0) + prob);
    add(0, pMiss);
    const throughProbNorm = pWound * pFail * pWardPass;
    for (let d of dmgDist) add(d.value, pHit * throughProbNorm * d.prob);
    add(0, pHit * (1 - throughProbNorm));
    if (critType === 'none' || critType === 'autoWound' || critType === 'doubleDamage') {
      let woundFactor = (critType === 'autoWound') ? 1 : pWound;
      let dmgMult = (critType === 'doubleDamage') ? 2 : 1;
      let throughCrit = woundFactor * pFail * pWardPass;
      for (let d of dmgDist) add(d.value * dmgMult, pCrit * throughCrit * d.prob);
      add(0, pCrit * (1 - throughCrit));
    } else if (critType === 'mortal') {
      add(0, pCrit * (1 - throughProbNorm));
      for (let d of dmgDist) add(d.value, pCrit * throughProbNorm * d.prob);
      let critBaseArr = [{ value: 0, prob: 1 - throughProbNorm }];
      for (let d of dmgDist) critBaseArr.push({ value: d.value, prob: throughProbNorm * d.prob });
      let critBase = new Map(); for (let { value, prob } of critBaseArr) critBase.set(value, (critBase.get(value) || 0) + prob);
      let mortalDist = [{ value: 0, prob: 1 - pWardPass }, { value: 1, prob: pWardPass }];
      let critCombined = convolveArrays(Array.from(critBase, ([v, p]) => ({ value: v, prob: p })), mortalDist);
      for (let { value, prob } of critCombined) { let old = out.get(value) || 0; out.set(value, old + pCrit * prob); }
      for (let [v, p] of critBase) { let old = out.get(v) || 0; out.set(v, old - pCrit * p); }
    } else if (critType === 'extraHit') {
      let critBase = new Map();
      for (let d of dmgDist) critBase.set(d.value, (critBase.get(d.value) || 0) + throughProbNorm * d.prob);
      critBase.set(0, (critBase.get(0) || 0) + (1 - throughProbNorm));
      let extraDist = allowExtra ? singleAttackDistribution(weapon, saveChar, wardVal, false, debuffs) : [{ value: 0, prob: 1 }];
      if (!extraDist) extraDist = [{ value: 0, prob: 1 }];
      let critCombined = convolveArrays(Array.from(critBase, ([v, p]) => ({ value: v, prob: p })), extraDist);
      for (let { value, prob } of critCombined) add(value, pCrit * prob);
    }
    let totalP = 0; for (let p of out.values()) totalP += p;
    if (totalP > 0 && Math.abs(totalP - 1) > 1e-10) { for (let [k, p] of out) out.set(k, p / totalP); }
    return Array.from(out, ([v, p]) => ({ value: v, prob: p })).sort((a, b) => a.value - b.value);
  }

  function computeWeaponDamageDistribution(profile, weaponIdx, saveChar, wardVal, debuffs = null) {
    const weapon = profile.weapons[weaponIdx];
    let perAttack = singleAttackDistribution(weapon, saveChar, wardVal, true, debuffs);
    if (!perAttack) return null;
    let attDist = distribution(weapon.attacks);
    if (!attDist) return null;
    // ‑1 Attack debuff: subtract 1 from each attack count
    if (debuffs?.attacks) attDist = shiftDistribution(attDist, -1);
    let maxAtt = Math.max(...attDist.map(a => a.value));
    let dists = [[{ value: 0, prob: 1.0 }]];
    for (let n = 1; n <= maxAtt; n++) dists[n] = convolveArrays(dists[n - 1], perAttack);
    let resultMap = new Map();
    for (let a of attDist) { let d = dists[a.value]; for (let { value, prob } of d) { resultMap.set(value, (resultMap.get(value) || 0) + prob * a.prob); } }
    let result = []; for (let [v, p] of resultMap) result.push({ value: v, prob: p }); result.sort((a, b) => a.value - b.value);
    return result;
  }

  function computeAllWeaponsDistribution(profile, saveChar, wardVal, debuffs = null) {
    let combined = [{ value: 0, prob: 1.0 }];
    for (let wi = 0; wi < profile.weapons.length; wi++) {
      let wd = computeWeaponDamageDistribution(profile, wi, saveChar, wardVal, debuffs);
      if (!wd) return null;
      combined = convolveArrays(combined, wd);
    }
    let models = profile.models;
    let modelDist = [{ value: 0, prob: 1.0 }];
    for (let i = 0; i < models; i++) modelDist = convolveArrays(modelDist, combined);
    if (profile.leader && profile.weapons.length > 0) {
      let leaderBonus = singleAttackDistribution(profile.weapons[0], saveChar, wardVal, true, debuffs);
      if (leaderBonus) modelDist = convolveArrays(modelDist, leaderBonus);
    }
    return modelDist;
  }

  function computeProfileDistribution(profile, saveChar, wardVal, debuffs = null) {
    return computeAllWeaponsDistribution(profile, saveChar, wardVal, debuffs);
  }

  // --- profile management (unchanged) ---
  function newWeapon(index) { return { id: Date.now() + Math.random(), name: 'Weapon ' + (index + 1), attacks: '2', hit: 4, wound: 4, rend: 0, damage: '1', critType: 'none' }; }
  function newProfile(name, color) { return { id: Date.now() + Math.random(), name, color, models: 1, leader: false, weapons: [newWeapon(0)], visible: true }; }

  function initProfiles() {
    profiles = [
      { id:1, name:'Dracoth Riders', color:PALETTE[0], models:2, leader:false, weapons:[{ id:101, name:'Storm-wreathed Blades', attacks:'3', hit:3, wound:3, rend:-1, damage:'1', critType:'mortal' }], visible:true },
      { id:2, name:'Vindictors', color:PALETTE[1], models:5, leader:true, weapons:[{ id:201, name:'Stormstrike Halberd', attacks:'2', hit:3, wound:4, rend:0, damage:'1', critType:'none' }], visible:true }
    ];
  }

  function getUnusedColor() { let u = profiles.map(p => p.color); for (let c of PALETTE) if (!u.includes(c)) return c; return PALETTE[profiles.length % PALETTE.length]; }
  function setProfileField(i, f, v) { if (i >= 0 && i < profiles.length) { profiles[i][f] = v; scheduleRefresh(); } }
  function setWeaponField(pi, wi, f, v) { if (pi >= 0 && pi < profiles.length && wi >= 0 && wi < profiles[pi].weapons.length) { profiles[pi].weapons[wi][f] = v; scheduleRefresh(); } }
  function addWeapon(pi) { if (pi >= 0 && pi < profiles.length && profiles[pi].weapons.length < 4) { profiles[pi].weapons.push(newWeapon(profiles[pi].weapons.length)); scheduleRefresh(); } }
  function removeWeapon(pi, wi) { if (pi >= 0 && pi < profiles.length && profiles[pi].weapons.length > 1 && wi >= 0 && wi < profiles[pi].weapons.length) { profiles[pi].weapons.splice(wi, 1); scheduleRefresh(); } }
  function scheduleRefresh() { if (pendingRender) return; pendingRender = true; requestAnimationFrame(() => { pendingRender = false; refreshAll(); }); }
  function refreshAll() { renderProfiles(); renderScreen2(); renderScreen3(); renderScreen4(); }

  // --- UI Rendering (Profiles, Screen 2, Screen 3) – unchanged except Screen 4 debuffs ---
  function renderProfiles() {
    let c = document.getElementById('profilesContainer'); c.innerHTML = '';
    profiles.forEach((p, idx) => {
      let card = document.createElement('div'); card.className = 'card';
      let totalAttacks = 0;
      p.weapons.forEach(w => { let ad = distribution(w.attacks); totalAttacks += Math.round((ad ? expectedValue(ad) : 0) * p.models); });
      if (p.leader && p.weapons.length > 0) totalAttacks += 1;
      card.innerHTML = `
        <div class="card-header"><span class="colour-dot" style="background:${p.color}"></span><input class="profile-name" value="${escHtml(p.name)}" onfocus="this.select()" onchange="setProfileField(${idx},'name',this.value)"><div style="display:flex;align-items:center;gap:4px;"><label class="visibility-toggle"><input type="checkbox" ${p.visible ? 'checked' : ''} onchange="setProfileField(${idx},'visible',this.checked)"> Show</label><button class="btn small" onclick="duplicateProfile(${idx})">📋</button>${profiles.length > 1 ? `<button class="btn small danger" onclick="deleteProfile(${idx})">🗑</button>` : ''}</div></div>
        <div class="stepper-row"><span class="stepper-label">Models</span><div class="stepper-control" id="models-stepper-${idx}"></div></div>
        <div class="stepper-row"><span class="stepper-label">Leader</span><label class="leader-toggle"><input type="checkbox" ${p.leader ? 'checked' : ''} onchange="setProfileField(${idx},'leader',this.checked)"> +1 Attack (Champion, uses Weapon 1)</label></div>
        <div class="total-attacks-info">Total attacks: <b class="pct">${totalAttacks}</b> across ${p.weapons.length} weapon${p.weapons.length > 1 ? 's' : ''}</div>
        <div id="weapons-container-${idx}"></div>
        <button class="btn small" onclick="addWeapon(${idx})" ${p.weapons.length >= 4 ? 'disabled style="opacity:0.4"' : ''}>➕ Add Weapon</button>
        <div class="summary-line" id="summary-${idx}">Avg — vs 4+ save</div>`;
      c.appendChild(card);
      buildModelStepper('models-stepper-' + idx, p.models, (v) => setProfileField(idx, 'models', v));
      renderWeapons(idx);
      updateSummaryLine(idx);
    });
  }

  function renderWeapons(pi) {
    let container = document.getElementById('weapons-container-' + pi);
    if (!container) return;
    let p = profiles[pi];
    container.innerHTML = '';
    p.weapons.forEach((w, wi) => {
      let wc = document.createElement('div'); wc.className = 'weapon-card';
      wc.innerHTML = `
        <div class="weapon-header">
          <input class="weapon-name" value="${escHtml(w.name)}" onfocus="this.select()" onchange="setWeaponField(${pi},${wi},'name',this.value)">
          ${p.weapons.length > 1 ? `<button class="btn tiny danger" onclick="removeWeapon(${pi},${wi})">✕ Remove</button>` : ''}
        </div>
        <div class="stepper-row"><span class="stepper-label">Attacks</span><input class="damage-input" id="watt-${pi}-${wi}" value="${escHtml(w.attacks)}" onfocus="this.select()" onchange="setWeaponField(${pi},${wi},'attacks',this.value);validateWeaponInput(${pi},${wi},'attacks')"><span class="error-hint" id="watt-err-${pi}-${wi}">Invalid</span></div>
        <div class="stepper-row"><span class="stepper-label">Hit</span><div class="stepper-control" id="whit-${pi}-${wi}"></div></div>
        <div class="stepper-row"><span class="stepper-label">Wound</span><div class="stepper-control" id="wwnd-${pi}-${wi}"></div></div>
        <div class="stepper-row"><span class="stepper-label">Rend</span><div class="stepper-control" id="wrend-${pi}-${wi}"></div></div>
        <div class="stepper-row"><span class="stepper-label">Damage</span><div style="display:flex;align-items:center;gap:4px;"><button class="stepper-btn small" onclick="adjustDamage(${pi},${wi},-1)">−</button><input class="damage-input" id="wdmg-${pi}-${wi}" value="${escHtml(w.damage)}" onfocus="this.select()" onchange="setWeaponField(${pi},${wi},'damage',this.value);validateWeaponInput(${pi},${wi},'damage')"><button class="stepper-btn small" onclick="adjustDamage(${pi},${wi},1)">+</button></div><span class="error-hint" id="wdmg-err-${pi}-${wi}">Invalid</span></div>
        <div class="radio-group" id="wcrit-${pi}-${wi}"></div>`;
      container.appendChild(wc);
      buildPlusStepper('whit-' + pi + '-' + wi, w.hit, 2, 6, (v) => setWeaponField(pi, wi, 'hit', v));
      buildPlusStepper('wwnd-' + pi + '-' + wi, w.wound, 2, 6, (v) => setWeaponField(pi, wi, 'wound', v));
      buildRendStepper('wrend-' + pi + '-' + wi, w.rend, (v) => setWeaponField(pi, wi, 'rend', v));
      buildWeaponCritRadios('wcrit-' + pi + '-' + wi, pi, wi, w.critType);
      validateWeaponInput(pi, wi, 'attacks');
      validateWeaponInput(pi, wi, 'damage');
    });
  }

  function adjustDamage(pi, wi, delta) { /* placeholder */ }
  function buildPlusStepper(id, cur, min, max, oc) { let e = document.getElementById(id); if (!e) return; e.innerHTML = ''; let m = doc('button', 'stepper-btn', '−'), p = doc('button', 'stepper-btn', '+'), d = doc('span', 'stepper-value', cur + '+'); m.onclick = () => { if (cur > min) oc(cur - 1); }; p.onclick = () => { if (cur < max) oc(cur + 1); }; e.append(m, d, p); }
  function buildRendStepper(id, cur, oc) { let e = document.getElementById(id); if (!e) return; e.innerHTML = ''; let m = doc('button', 'stepper-btn', '−'), p = doc('button', 'stepper-btn', '+'), t = cur === 0 ? '—' : '−' + Math.abs(cur), d = doc('span', 'stepper-value', t); m.onclick = () => { if (cur > -6) oc(cur - 1); }; p.onclick = () => { if (cur < 0) oc(cur + 1); }; e.append(m, d, p); }
  function buildModelStepper(id, cur, oc) { let e = document.getElementById(id); if (!e) return; e.innerHTML = ''; let m = doc('button', 'stepper-btn', '−'), p = doc('button', 'stepper-btn', '+'), d = doc('span', 'stepper-value', String(cur)); m.onclick = () => { if (cur > 1) oc(cur - 1); }; p.onclick = () => { if (cur < 20) oc(cur + 1); }; e.append(m, d, p); }
  function buildWeaponCritRadios(id, pi, wi, sel) { let e = document.getElementById(id); if (!e) return; let t = [{ val: 'none', label: 'None' }, { val: 'mortal', label: 'Mortal on Crit' }, { val: 'autoWound', label: 'Auto-wound' }, { val: 'doubleDamage', label: 'Double Damage' }, { val: 'extraHit', label: 'Crit 2 Hits' }]; e.innerHTML = t.map(x => `<label class="radio-option"><input type="radio" name="wcrit${pi}-${wi}" value="${x.val}" ${sel === x.val ? 'checked' : ''} onchange="setWeaponField(${pi},${wi},'critType','${x.val}')">${x.label}</label>`).join(''); }
  function validateWeaponInput(pi, wi, field) { let i = document.getElementById((field === 'attacks' ? 'watt' : 'wdmg') + '-' + pi + '-' + wi), e = document.getElementById((field === 'attacks' ? 'watt-err' : 'wdmg-err') + '-' + pi + '-' + wi); if (!i || !e) return; let v = validateExpression(i.value); i.classList.toggle('invalid', !v); e.classList.toggle('visible', !v); }
  function updateSummaryLine(idx) { let p = profiles[idx]; let d = computeProfileDistribution(p, 4, 0); let avg = d ? expectedValue(d).toFixed(2) : '—'; let el = document.getElementById('summary-' + idx); if (el) el.textContent = 'Avg ' + avg + ' damage vs 4+ save (no ward)'; }
  function doc(tag, cls, text) { let e = document.createElement(tag); if (cls) e.className = cls; if (text !== undefined) e.textContent = text; return e; }
  function escHtml(s) { return String(s).replace(/[&<>"']/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[m]); }
  function duplicateProfile(idx) { if (profiles.length >= 4) return; let c = JSON.parse(JSON.stringify(profiles[idx])); c.id = Date.now() + Math.random(); c.name += ' copy'; c.color = getUnusedColor(); profiles.splice(idx + 1, 0, c); scheduleRefresh(); }
  function deleteProfile(idx) { if (profiles.length <= 1) return; profiles.splice(idx, 1); scheduleRefresh(); }
  document.getElementById('addProfileBtn').onclick = () => { if (profiles.length >= 4) return; profiles.push(newProfile('Profile ' + (profiles.length + 1), getUnusedColor())); scheduleRefresh(); };

  // ==================== SCREEN 2 (unchanged) ====================
  function renderScreen2() {
    let ward = parseInt(document.getElementById('globalWardSelect').value), saves = [0,6,5,4,3,2];
    document.getElementById('combineWeaponsToggle').checked = combineWeapons;
    let lines = [];
    profiles.filter(p => p.visible).forEach(p => {
      if (combineWeapons) {
        lines.push({ name: p.name, color: p.color, getValues: () => saves.map(s => { let d = computeProfileDistribution(p, s, ward); return d ? expectedValue(d) : 0; }) });
      } else {
        p.weapons.forEach((w, wi) => {
          lines.push({ name: w.name || (p.name + ' W' + (wi + 1)), color: p.color, getValues: () => {
            let wp = { ...p, weapons: [w] };
            return saves.map(s => { let d = computeProfileDistribution(wp, s, ward); return d ? expectedValue(d) : 0; });
          }});
        });
      }
    });
    let data = lines.map(l => ({ name: l.name, color: l.color, values: l.getValues() }));
    let cc = document.getElementById('saveChartContainer'), tc = document.getElementById('saveTableContainer');
    if (data.length === 0) { cc.innerHTML = '<p style="color:#888;padding:20px;">No visible profiles</p>'; tc.innerHTML = ''; return; }
    let mv = Math.max(...data.flatMap(d => d.values), 0.1), w = 650, h = 260, pL = 55, pR = 35, pT = 20, pB = 35, pW = w - pL - pR, pH = h - pT - pB;
    let svg = `<svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="xMidYMid meet">`;
    for (let i = 0; i <= 4; i++) { let yV = (mv / 4) * i, y = h - pB - (yV / mv) * pH; svg += `<line x1="${pL}" y1="${y}" x2="${w - pR}" y2="${y}" stroke="#333" stroke-dasharray="3,3"/><text x="${pL - 6}" y="${y + 4}" text-anchor="end" fill="#888" font-size="11" font-family="Georgia,serif">${yV.toFixed(1)}</text>`; }
    saves.forEach((s, i) => { let x = pL + (i / (saves.length - 1)) * pW; svg += `<text x="${x}" y="${h - 6}" text-anchor="middle" fill="#888" font-size="11" font-family="Georgia,serif">${s === 0 ? 'None' : s + '+'}</text>`; });
    data.forEach(d => { let pts = d.values.map((v, i) => `${pL + (i / (saves.length - 1)) * pW},${h - pB - (v / mv) * pH}`).join(' '); svg += `<polyline points="${pts}" fill="none" stroke="${d.color}" stroke-width="2.5" stroke-linejoin="round"/>`; d.values.forEach((v, i) => { let x = pL + (i / (saves.length - 1)) * pW, y = h - pB - (v / mv) * pH; svg += `<circle cx="${x}" cy="${y}" r="4" fill="${d.color}"/>`; }); });
    data.forEach((d, i) => { let label = escHtml(d.name); if (label.length > 14) label = label.slice(0,12)+'…'; svg += `<rect x="${w - 160}" y="${pT + i * 18}" width="12" height="12" fill="${d.color}" rx="2"/><text x="${w - 144}" y="${pT + 11 + i * 18}" fill="#c0c0c0" font-size="11" font-family="Georgia,serif">${label}</text>`; });
    svg += '</svg>'; cc.innerHTML = svg;
    let html = '<table><tr><th>Save</th>' + data.map(d => `<th>${escHtml(d.name)}</th>`).join('') + '</tr>';
    saves.forEach((s, i) => { let best = Math.max(...data.map(d => d.values[i])); html += `<tr><td>${s === 0 ? 'None' : s + '+'}</td>`; data.forEach(d => { let v = d.values[i].toFixed(2); html += `<td class="${d.values[i] === best && best > 0 && data.filter(x => x.values[i] === best).length === 1 ? 'best-cell' : ''}">${v}</td>`; }); html += '</tr>'; });
    html += '</table>'; tc.innerHTML = html;
  }
  document.getElementById('globalWardSelect').onchange = () => renderScreen2();

  // ==================== SCREEN 3 (unchanged) ====================
  function renderScreen3() {
    let save = parseInt(document.getElementById('distSaveSelect').value), ward = parseInt(document.getElementById('distWardSelect').value);
    let sel = document.getElementById('distProfileSelect');
    sel.innerHTML = '<option value="all">All Profiles</option>' + profiles.map((p, i) => `<option value="${i}" ${String(i) === distSelectedVal ? 'selected' : ''}>${escHtml(p.name)}</option>`).join('');
    let val = sel.value; distSelectedVal = val;
    let allDists = [];
    if (val === 'all') {
      profiles.forEach(p => {
        let d = computeProfileDistribution(p, save, ward);
        if (d) allDists.push({ name: p.name, color: p.color, dist: d });
      });
    } else {
      let p = profiles[parseInt(val)];
      if (combineWeapons) {
        let d = computeProfileDistribution(p, save, ward);
        if (d) allDists.push({ name: p.name, color: p.color, dist: d });
      } else {
        p.weapons.forEach((w, wi) => {
          let wp = { ...p, weapons: [w] };
          let d = computeProfileDistribution(wp, save, ward);
          if (d) allDists.push({ name: w.name || (p.name + ' W' + (wi + 1)), color: p.color, dist: d });
        });
      }
    }
    let cc = document.getElementById('distChartContainer'), sc = document.getElementById('distStatsContainer');
    if (allDists.length === 0) { cc.innerHTML = '<p style="color:#c0392b;padding:20px;">Invalid expression</p>'; sc.innerHTML = ''; return; }
    let globalMax = Math.max(...allDists.flatMap(d => d.dist.map(x => x.value)), 1);
    let globalMaxP = Math.max(...allDists.flatMap(d => d.dist.map(x => x.prob)), 0.001);
    let displayMax = Math.min(globalMax, 40);
    let barW = Math.max(8, Math.min(30, 560 / (allDists.length * (displayMax + 1) + 2)));
    let groupW = barW * allDists.length + 3;
    let tw = Math.max(620, (displayMax + 1) * (groupW + 2) + 70), h = 280, pL = 55, pR = 35, pT = 25, pB = 40, pH = h - pT - pB;
    let svg = `<svg viewBox="0 0 ${tw} ${h}" preserveAspectRatio="xMidYMid meet">`;
    for (let i = 0; i <= 4; i++) { let yV = (globalMaxP / 4) * i, y = h - pB - (yV / globalMaxP) * pH; svg += `<line x1="${pL}" y1="${y}" x2="${tw - pR}" y2="${y}" stroke="#333"/><text x="${pL - 6}" y="${y + 4}" text-anchor="end" fill="#888" font-size="11" font-family="Georgia,serif">${(yV * 100).toFixed(0)}%</text>`; }
    for (let v = 0; v <= displayMax; v++) {
      allDists.forEach(({ color, dist }, di) => { let d = dist.find(x => x.value === v), prob = d ? d.prob : 0; let x = pL + v * (groupW + 2) + di * barW; let barH = Math.max(prob > 0 ? 1.5 : 0, (prob / globalMaxP) * pH); svg += `<rect x="${x}" y="${h - pB - barH}" width="${barW - 1}" height="${barH}" fill="${color}" opacity="0.85"/>`; });
      if (v % Math.max(1, Math.floor(displayMax / 10)) === 0 || v === displayMax) { let x = pL + v * (groupW + 2) + (allDists.length * barW) / 2; svg += `<text x="${x}" y="${h - 10}" text-anchor="middle" fill="#888" font-size="10" font-family="Georgia,serif">${v}</text>`; }
    }
    allDists.forEach(({ name, color }, i) => { let label = escHtml(name); if (label.length > 14) label = label.slice(0,12)+'…'; svg += `<rect x="${tw - 160}" y="${pT + i * 18}" width="12" height="12" fill="${color}" rx="2"/><text x="${tw - 144}" y="${pT + 11 + i * 18}" fill="#c0c0c0" font-size="11" font-family="Georgia,serif">${label}</text>`; });
    svg += '</svg>'; cc.innerHTML = '<div class="scroll-hint">← scroll chart →</div>' + svg;
    let sh = '';
    allDists.forEach(({ name, color, dist }) => {
      let sorted = [...dist].sort((a, b) => a.value - b.value);
      let mean = expectedValue(dist);
      let p5 = (probGE(dist, 5) * 100).toFixed(1);
      let p10 = (probGE(dist, 10) * 100).toFixed(1);
      let p15 = (probGE(dist, 15) * 100).toFixed(1);
      let cum = 0, p25 = null, p75 = null;
      for (let d of sorted) { cum += d.prob; if (cum >= 0.25 && p25 === null) p25 = d.value; if (cum >= 0.75 && p75 === null) { p75 = d.value; break; } }
      if (p75 === null) p75 = sorted[sorted.length - 1].value;
      if (p25 === null) p25 = sorted[0].value;
      sh += `<div style="margin-bottom:10px;border-left:3px solid ${color};padding-left:10px;"><b style="color:${color}">${escHtml(name)}</b><div class="stat-grid"><div>Mean: <b class="pct">${mean.toFixed(2)}</b></div><div>Min/Max: <b class="pct">${sorted[0].value}/${sorted[sorted.length - 1].value}</b></div><div>P(≥5): <b class="pct">${p5}%</b></div><div>P(≥10): <b class="pct">${p10}%</b></div><div>P(≥15): <b class="pct">${p15}%</b></div><div>25th–75th: <b class="pct">${p25 === p75 ? p25 + ' (all)' : p25 + ' – ' + p75}</b></div></div></div>`;
    });
    sc.innerHTML = sh;
  }
  document.getElementById('distSaveSelect').onchange = () => renderScreen3();
  document.getElementById('distWardSelect').onchange = () => renderScreen3();
  document.getElementById('distProfileSelect').onchange = function () { distSelectedVal = this.value; renderScreen3(); };

  // ==================== SCREEN 4 (CHECKBOX DEBUFFS + FIXED MATH) ====================
  function buildKillSteppers() {
    function ms(id, key, min, max) { let e = document.getElementById(id); if (!e) return; let cur = killState[key]; e.innerHTML = ''; let m = doc('button', 'stepper-btn', '−'), p = doc('button', 'stepper-btn', '+'), d = doc('span', 'stepper-value', String(cur)); m.onclick = () => { if (cur > min) { cur--; killState[key] = cur; d.textContent = cur; renderScreen4(); } }; p.onclick = () => { if (cur < max) { cur++; killState[key] = cur; d.textContent = cur; renderScreen4(); } }; e.append(m, d, p); }
    ms('killWoundsStepper','wounds',1,40); ms('killModelsStepper','models',1,20);
  }

  function buildDebuffToggles() {
    let container = document.getElementById('debuffToggles');
    if (!container) return;
    container.innerHTML = '';
    const options = [
      { key:'hit', label:'‑1 Hit' },
      { key:'wound', label:'‑1 Wound' },
      { key:'attacks', label:'‑1 Attack' }
    ];
    options.forEach(opt => {
      let label = document.createElement('label');
      label.className = 'toggle-option';
      let input = document.createElement('input');
      input.type = 'checkbox';
      input.checked = killDebuffs[opt.key];
      input.onchange = () => {
        killDebuffs[opt.key] = input.checked;
        renderScreen4();
      };
      label.appendChild(input);
      label.appendChild(document.createTextNode(opt.label));
      container.appendChild(label);
    });
  }

  function clearDebuffs() {
    killDebuffs = { hit: false, wound: false, attacks: false };
    renderScreen4();
  }

  function renderScreen4() {
    buildKillSteppers();
    buildDebuffToggles();
    let save = parseInt(document.getElementById('killSaveSelect').value),
        ward = parseInt(document.getElementById('killWardSelect').value),
        tw = killState.wounds * killState.models;
    // use debuffs if any active
    let deb = (killDebuffs.hit || killDebuffs.wound || killDebuffs.attacks) ? killDebuffs : null;
    let sc = document.getElementById('killStatsContainer'),
        cc = document.getElementById('killChartContainer'),
        bc = document.getElementById('killBreakdownContainer');
    if (profiles.length === 0) { sc.innerHTML = '<p style="color:#888;">No profiles</p>'; cc.innerHTML = ''; bc.innerHTML = ''; return; }
    let results = profiles.map(p => {
      let d = computeProfileDistribution(p, save, ward, deb);
      if (!d) return { name:p.name, color:p.color, pkFull:0, pkHalf:0, pkOne:0, expKills:0, bd:[] };
      let pkF = probGE(d, tw), pkH = probGE(d, Math.ceil(tw/2)), pkO = probGE(d, killState.wounds);
      let raw = expectedValue(d)/killState.wounds, ek = Math.min(raw, killState.models);
      let bd = []; for (let m=1; m<=killState.models; m++) bd.push({ models:m, probAtLeast: probGE(d, m*killState.wounds) });
      return { name:p.name, color:p.color, pkFull:pkF, pkHalf:pkH, pkOne:pkO, expKills:ek, bd };
    });
    sc.innerHTML = results.map(r => `<div class="card" style="margin-bottom:8px;"><b style="color:${r.color}">${escHtml(r.name)}</b><div style="margin-top:4px;font-size:13px;">P(kill ≥1): <b class="pct">${(r.pkOne*100).toFixed(1)}%</b> | P(kill ≥half): <b class="pct">${(r.pkHalf*100).toFixed(1)}%</b> | P(kill all): <b class="pct">${(r.pkFull*100).toFixed(1)}%</b><br>Expected models killed: <b class="pct">${r.expKills.toFixed(2)}</b></div></div>`).join('');
    let mP = Math.max(...results.map(r => r.pkFull), 0.01), bh = results.map(r => { let pct = (r.pkFull/mP)*100; return `<div class="bar-row"><span class="bar-label">${escHtml(r.name)}</span><div style="flex:1;background:#1a1a1a;border-radius:4px;height:18px;"><div class="bar-fill" style="width:${pct}%;background:${r.color};"></div></div><span style="font-size:12px;width:50px;">${(r.pkFull*100).toFixed(1)}%</span></div>`; }).join(''); cc.innerHTML = `<h4 style="color:#c9a84c;margin-bottom:8px;">P(kill entire unit)</h4>${bh}`;
    if (results.length > 0 && results[0].bd.length > 0) { let th = '<table><tr><th>Models killed</th>'+results.map(r => `<th>${escHtml(r.name)}</th>`).join('')+'</tr>'; for (let i=0; i<killState.models; i++) { th += `<tr><td>≥${i+1}</td>`; results.forEach(r => { let b = r.bd[i] || { probAtLeast:0 }; th += `<td><b class="pct">${(b.probAtLeast*100).toFixed(1)}%</b></td>`; }); th += '</tr>'; } th += '</table>'; bc.innerHTML = '<div class="scroll-hint">← scroll table →</div>'+th; } else { bc.innerHTML = '<p style="color:#c0392b;">Invalid expression</p>'; }
  }
  document.getElementById('killSaveSelect').onchange = () => renderScreen4();
  document.getElementById('killWardSelect').onchange = () => renderScreen4();

  // ==================== NAVIGATION ====================
  document.querySelectorAll('.nav-btn').forEach(b => { b.addEventListener('click', () => { document.querySelectorAll('.nav-btn').forEach(x => x.classList.remove('active')); b.classList.add('active'); let s = b.dataset.screen; document.querySelectorAll('.screen').forEach(x => x.classList.remove('active')); document.getElementById('screen'+s).classList.add('active'); if (s==='2') renderScreen2(); if (s==='3') renderScreen3(); if (s==='4') renderScreen4(); }); });

  function fullInit() { initProfiles(); renderProfiles(); renderScreen2(); renderScreen3(); renderScreen4(); }
  fullInit();
</script>
